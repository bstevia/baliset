{
  "compilerOptions": {
    "target": "ES2019",
    "module": "none",
    "lib": ["ES2019", "DOM"],
    "strict": true,
    "noImplicitAny": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true,
    "esModuleInterop": false,
    "forceConsistentCasingInFileNames": true,
    "removeComments": true,
    "outFile": "./content.js",
    "rootDir": "./src"
  },
  "include": ["src/**/*.ts"]
}
